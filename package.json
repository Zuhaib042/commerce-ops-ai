{
  "name": "commerceops-ai-os",
  "version": "0.1.0",
  "private": true,
  "description": "AI automation and systems engineering portfolio project for e-commerce operations.",
  "scripts": {
    "setup": "npm install && npm run py:venv && npm run py:install",
    "py:venv": "python3 -m venv .venv",
    "py:install": ".venv/bin/python -m pip install --upgrade pip && .venv/bin/python -m pip install -r requirements.txt",
    "data:download": "node scripts/download-public-data.mjs",
    "data:convert": ".venv/bin/python scripts/export-online-retail-csv.py",
    "data:bootstrap": "npm run data:download && npm run data:convert && npm run data:prepare",
    "data:prepare": "node scripts/prepare-warehouse-data.mjs --scale small",
    "data:prepare:medium": "node scripts/prepare-warehouse-data.mjs --scale medium",
    "data:prepare:large": "node scripts/prepare-warehouse-data.mjs --scale large",
    "db:up": "docker compose up -d postgres adminer",
    "db:down": "docker compose down",
    "db:schema": "psql \"postgresql://commerceops:commerceops@localhost:5432/commerceops\" -f database/schema.sql",
    "db:load": "psql \"postgresql://commerceops:commerceops@localhost:5432/commerceops\" -f data/generated/load.sql",
    "db:reset": "npm run db:schema && npm run db:load",
    "api:dev": "tsx watch apps/api/src/main.ts",
    "api:start": "tsx apps/api/src/main.ts",
    "api:build": "tsc -p tsconfig.json",
    "api:prod": "node dist/apps/api/src/main.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@faker-js/faker": "^9.9.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "adm-zip": "^0.5.16",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.2",
    "fastify": "^5.8.5",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
